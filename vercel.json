{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/notas",
      "destination": "/src/public/notas.html"
    }
  ],
  "routes": [
    {
      "src": "/googledbcecb6033bfd83d.html",
      "dest": "/src/public/googledbcecb6033bfd83d.html"
    },
    {
      "src": "/(.*)",
      "dest": "/src/server.js"
    }
  ]
}
